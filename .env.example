# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# Optional: name of the tab with exchange rates (columns: Currency, Rate to EUR). Default: Rates
# GOOGLE_SHEETS_RATES_SHEET=Rates

# Service Account: either JSON string (e.g. for Railway) or path to file
# Option A – JSON string in .env (recommended for Railway)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Option B – path to JSON file (local)
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
