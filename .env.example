# Telegram (otrzymasz od @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Notion Internal Integration Secret (z notion.so/my-integrations)
NOTION_SECRET=secret_...

# ID bazy Expenses (z URL strony bazy – 32 znaki, bez myślników)
NOTION_EXPENSES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID bazy Income (potrzebne przy wyborze Entrata – Conto + Income Source)
NOTION_INCOME_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcjonalnie – jeśli w Expenses masz Relation do Accounts/Categories,
# podaj ID tych baz, żeby bot mógł rozpoznawać konta i kategorie po nazwie:
# NOTION_ACCOUNTS_DATABASE_ID=...
# NOTION_CATEGORIES_DATABASE_ID=...
