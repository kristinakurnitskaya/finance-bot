# Telegram (otrzymasz od @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Google Sheets – ID arkusza (z URL: docs.google.com/spreadsheets/d/ ID /edit)
GOOGLE_SHEETS_SPREADSHEET_ID=twoj_spreadsheet_id

# Google Service Account – cały JSON (jeden wiersz, bez enterów)
# Z Google Cloud Console: IAM → Service Accounts → Create Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Opcjonalnie – nazwa arkusza z transakcjami (domyślnie: Transactions)
# GOOGLE_SHEETS_TRANSACTIONS_SHEET=Transactions
